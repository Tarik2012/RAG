# =========================
# Django
# =========================
SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=

# =========================
# Database (PostgreSQL)
# =========================
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=
OPENAI_MODEL=
RAG_LLM_PROVIDER=


TAVILY_API_KEY=

CELERY_BROKER_URL=

GITHUB_PAT=

# --- CSRF (obligatorio en producción con HTTPS, ej. Railway) ---
CSRF_TRUSTED_ORIGINS=https://tu-app.up.railway.app

# --- Modelos OpenAI por rol ---
OPENAI_AGENT_MODEL=gpt-4.1
OPENAI_JUDGE_MODEL=gpt-4o-mini

# --- Almacenamiento S3 (usado en producción para compartir archivos entre web y worker) ---
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_DEFAULT_REGION=eu-west-1
AWS_ENDPOINT_URL=https://s3.eu-west-1.amazonaws.com

# --- LangSmith (observabilidad del agente; opcional pero recomendado) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-key
LANGCHAIN_PROJECT=taritech
